# ==============================================================================
# CONFIGURACIÓN DE GMAIL_LEADS_WORKER - EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo a un archivo llamado .env y llena los campos correspondientes.
# ==============================================================================

# Cuenta de Gmail desde donde se leerán los correos de leads
GMAIL_USER=tu_usuario@grupogranauto.mx
# Contraseña de aplicación de Gmail (16 caracteres, sin espacios si se desea, o con ellos)
GMAIL_APP_PASS=tu_contraseña_de_aplicacion

# Configuración del servidor de correo (por defecto para Gmail IMAP)
IMAP_SERVER=imap.gmail.com
# Filtro por asunto para identificar correos de leads
SUBJECT_FILTER=DealerOn

# ID de la hoja de Google Sheets donde se guardarán los leads
GOOGLE_SHEET_ID=tu_spreadsheet_id_aqui
# Nombre de la pestaña de la hoja de cálculo
SHEET_NAME=Sheet1

# JSON de credenciales de Google Service Account (en una sola línea)
# Requerido en entornos como Railway (no uses archivos locales en producción)
GOOGLE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}
# Opcional (solo desarrollo local): Ruta local al archivo JSON de credenciales de Google
CREDS_PATH=credentials.json

# Token de acceso de Meta (WhatsApp Business Cloud API)
META_ACCESS_TOKEN=tu_meta_access_token_aqui
# ID del número telefónico de WhatsApp de Meta
META_PHONE_NUMBER_ID=tu_phone_number_id_aqui
# Nombre de la plantilla de WhatsApp para alertas de asesores
WHATSAPP_TEMPLATE_NAME=dealeron_lead_notification

# Lista de números telefónicos (receptores de alertas de asesores) separados por comas
# Ejemplo: 526623587553,526623254234
WHATSAPP_RECIPIENTS=52XXXXXXXXXX,52XXXXXXXXXX
